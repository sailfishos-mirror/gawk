msgstr "‏save اسم_الملف - احفظ أوامر الجلسة في ملف"

#: command.y:880
msgid "set var = value - assign value to a scalar variable"
msgstr "‏set var = value - عين قيمة لمتغير سلمي"

#: command.y:882
msgid "silent - suspends usual message when stopped at a breakpoint/watchpoint"
msgstr "‏silent - يعلق الرسالة المعتادة عند التوقف عند نقطة توقف/مراقبة"

