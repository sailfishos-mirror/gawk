msgstr "‏stepi [العدد] - خطوة تعليمة واحدة بالضبط"

#: command.y:890
msgid "tbreak [[filename:]N|function] - set a temporary breakpoint"
msgstr "‏tbreak [[اسم_الملف:]N|الدالة] - اضبط نقطة توقف مؤقتة"

#: command.y:892
msgid "trace on|off - print instruction before executing"
msgstr "‏trace on|off - اطبع التعليمة قبل التنفيذ"

