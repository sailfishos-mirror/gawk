msgid "source file - execute commands from file"
msgstr "‏source ملف - نفذ الأوامر من ملف"

#: command.y:886
msgid "step [COUNT] - step program until it reaches a different source line"
msgstr "‏step [COUNT] - خطوة في البرنامج حتى يصل إلى سطر مصدري مختلف"

#: command.y:888
